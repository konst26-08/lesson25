API_PORT=3001
DATABASE_URL=postgresql://stepup_app:change_me_strong_password@localhost:5432/stepup
JWT_SECRET=replace_with_strong_secret_at_least_32_chars
JWT_EXPIRES_IN=1d
API_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Логи API (JSON в stdout + опционально файл)
LOG_LEVEL=info
LOG_SERVICE=stepup-api
# Централизованное хранение: одна JSONL-строка = одна запись
LOG_FILE=logs/api.log
# Отключить access-логи: DISABLE_HTTP_LOG=1

# Frontend (Vite): пусто = запросы на /api через proxy dev-сервера
VITE_API_BASE_URL=

# Yandex OAuth2 (опционально; без них OAuth-маршруты не регистрируются)
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/yandex/callback
OAUTH_FRONTEND_SUCCESS_URL=http://localhost:5173/login/oauth/callback

# Yandex Metrika (счётчик на фронтенде)
VITE_YM_COUNTER_ID=109394182

# GitHub Actions (опционально): URL production-сайта для smoke test после deploy
# NETLIFY_SITE_URL=https://regal-sunflower-1a7fff.netlify.app
